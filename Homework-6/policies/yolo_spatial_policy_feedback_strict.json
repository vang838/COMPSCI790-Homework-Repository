{
  "description": "Strict YOLO feedback spatial policy. Current-frame rules are stricter, so recent YOLO detections are needed to keep object regions active.",

  "frame_grid": {
    "rows": 3,
    "cols": 3
  },

  "modes": {
    "skip": {
      "imgsz": 0
    },
    "detect": {
      "imgsz": 320
    }
  },

  "rules": [
    {
      "name": "recent_detection_keep_alive",
      "condition": "feedback_score >= 0.40",
      "mode": "detect"
    },
    {
      "name": "high_importance_detect",
      "condition": "importance >= 0.75",
      "mode": "detect"
    },
    {
      "name": "motion_region_detect",
      "condition": "motion >= 0.60 and importance >= 0.50",
      "mode": "detect"
    },
    {
      "name": "default_skip",
      "condition": "true",
      "mode": "skip"
    }
  ]
}